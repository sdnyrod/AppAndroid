{
  "expo": {
    "name": "CREW",
    "slug": "crew-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "crew-cwm",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "package": "com.crewcwm.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDl8aE-uKk5MpNowptzJ0UguDL0V4T9Bfo"
        }
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crewcwm.app",
      "infoPlist": {
        "NSCameraUsageDescription": "CREW needs camera access to take photos and videos of job sites.",
        "NSPhotoLibraryUsageDescription": "CREW needs photo library access to upload existing photos and videos to projects.",
        "NSMicrophoneUsageDescription": "CREW needs microphone access to record videos with audio.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CREW needs your location to track work hours and job site attendance."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "CREW needs photo library access to upload existing photos and videos to projects.",
          "cameraPermission": "CREW needs camera access to take photos and videos of job sites."
        }
      ],
      "expo-document-picker",
      "expo-asset",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "CREW uses Face ID for quick and secure login."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d3f678eb-209e-4e41-8416-6ecfa8840deb"
      },
      "apiBaseUrl": "https://crew-cwm.com"
    },
    "owner": "crew-cwm"
  }
}